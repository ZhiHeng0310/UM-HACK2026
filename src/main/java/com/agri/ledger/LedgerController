package com.agri.ledger;

import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/api/ledger")
@CrossOrigin(origins = "*") // Allows your browser to talk to Java
public class LedgerController {

    private final DecisionLogger decisionLogger = new DecisionLogger();
    private final UserActionTracker actionTracker = new UserActionTracker(decisionLogger);

    // 🔥 FIX: This is the missing "door" for the history button
// Inside LedgerController.java
@GetMapping("/all")
public ResponseEntity<List<LedgerEntry>> getAllDecisions() {
    try {
        List<LedgerEntry> entries = decisionLogger.loadAll();
        System.out.println("✅ Ledger loaded: " + entries.size() + " entries found.");
        return ResponseEntity.ok(entries);
    } catch (Exception e) {
        // This will print the REAL error in your IntelliJ console
        System.err.println("❌ LEDGER ERROR: " + e.getMessage());
        e.printStackTrace(); 
        return ResponseEntity.internalServerError().build();
    }
}

    @PostMapping("/save")
    public ResponseEntity<String> saveDecision(@RequestBody Map<String, String> payload) {
        String cropName = payload.getOrDefault("plotId", ""); 
        String chosenStrategy = payload.getOrDefault("chosenStrategy", "");
        try {
            List<LedgerEntry> all = decisionLogger.loadAll();
            String targetId = null;
            // Find the latest recommendation for this crop
            for (int i = all.size() - 1; i >= 0; i--) {
                if (cropName.equalsIgnoreCase(all.get(i).getRecommendedCrop())) {
                    targetId = all.get(i).getRecommendationId();
                    break;
                }
            }
            if (targetId != null) {
                actionTracker.recordChoice(targetId, chosenStrategy);
                return ResponseEntity.ok("Saved to Ledger");
            }
            return ResponseEntity.badRequest().body("No recent recommendation found.");
        } catch (Exception e) {
            return ResponseEntity.internalServerError().body(e.getMessage());
        }
    }
}
