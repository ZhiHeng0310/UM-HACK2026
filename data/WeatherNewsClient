package data;

import java.util.*;
import java.util.stream.Collectors;

public class WeatherNewsClient {

    private final Random random = new Random();

    public String fetchUnstructuredContext(String region) {

        List<String> weatherOptions = Arrays.asList(
            "[WEATHER][RISK=MEDIUM] Heavy rainfall alert from MET Malaysia for " + region,
            "[WEATHER][RISK=LOW] Ideal sunshine levels predicted for next 10 days in " + region,
            "[WEATHER][RISK=HIGH] Flash flood warning for low-lying plots in " + region,
            "[WEATHER][RISK=MEDIUM] Mild drought conditions; irrigation optimization recommended for " + region
        );

        List<String> newsPool = Arrays.asList(
            "[POLICY][CROP=GINGER][IMPACT=POSITIVE][MAG=HIGH] 15% fertilizer subsidy increase announced.",
            "[MARKET][CROP=CORN][IMPACT=NEGATIVE][MAG=MEDIUM] Global supply glut expected to reduce prices.",
            "[MARKET][CROP=CHILI][IMPACT=POSITIVE][MAG=HIGH] Rising demand in urban KL/PJ markets.",
            "[DISEASE][CROP=LEAFY_GREENS][RISK=HIGH] High humidity increasing fungal infection risk.",
            "[LOGISTICS][IMPACT=NEGATIVE][MAG=LOW] Toll rate hike affecting transport costs."
        );

        String weather = weatherOptions.get(random.nextInt(weatherOptions.size()));

        Collections.shuffle(newsPool);
        List<String> selectedNews = newsPool.stream()
                                            .limit(2)
                                            .collect(Collectors.toList());

        StringBuilder contextBuilder = new StringBuilder();
        contextBuilder.append("--- LATEST UNSTRUCTURED FIELD INTELLIGENCE ---\n");
        contextBuilder.append("Target Region: ").append(region).append("\n");
        contextBuilder.append("Analysis Timestamp: ").append(java.time.LocalDateTime.now()).append("\n\n");

        contextBuilder.append("- ").append(weather).append("\n");
        for (String news : selectedNews) {
            contextBuilder.append("- ").append(news).append("\n");
        }

        return contextBuilder.toString();
    }
}